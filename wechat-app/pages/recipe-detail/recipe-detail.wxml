<block wx:if="{{showWebView}}">
  <!-- 全屏 WebView 播放 -->
  <view class="web-view-container">
    <web-view src="{{webViewUrl}}"></web-view>
    <view class="web-view-back" bindtap="closeWebView">
      <image src="/images/back.png" mode="aspectFit"/>
      <text>返回</text>
    </view>
  </view>
</block>

<block wx:else>
  <view class="container">
    <!-- 视频类型菜谱 -->
    <block wx:if="{{recipe.type === 'video'}}">
      <!-- 视频播放区 -->
      <view class="video-hero-section">
        <!-- 平台视频（抖音、快手等）显示封面和跳转按钮 -->
        <block wx:if="{{isPlatformVideo}}">
          <image class="video-cover" 
                 src="{{recipe.coverUrl || recipe.imageUrl || '/images/default-food.png'}}" 
                 mode="aspectFill"/>
          <view class="play-overlay" bindtap="openVideoLink">
            <view class="play-btn">
              <image src="/images/play.png" mode="aspectFit"/>
            </view>
            <text class="play-text">{{canOpenApp ? '点击打开' + platformName : '复制链接去' + platformName}}观看</text>
          </view>
        </block>
        <!-- 普通视频链接直接使用 video 播放 -->
        <block wx:else>
          <video class="video-player" 
                 src="{{recipe.videoUrl || recipe.sourceUrl}}" 
                 poster="{{recipe.coverUrl || recipe.imageUrl}}"
                 controls
                 show-center-play-btn
                 enable-progress-gesture
                 object-fit="contain"></video>
        </block>
        <view class="back-btn" bindtap="goBack">
          <image src="/images/back.png" mode="aspectFit"/>
        </view>
      </view>

      <!-- 视频菜谱信息 -->
      <view class="video-info-section">
        <text class="recipe-name">{{recipe.name}}</text>
        
        <!-- 备注 -->
        <view class="note-section" wx:if="{{recipe.note}}">
          <text class="note-label">备注</text>
          <text class="note-content">{{recipe.note}}</text>
        </view>
        
        <!-- 播放按钮 -->
        <view class="open-platform-btn" bindtap="openVideoLink" wx:if="{{isPlatformVideo && canOpenApp}}">
          <image src="/images/play.png" mode="aspectFit"/>
          <text>打开{{platformName}}观看</text>
        </view>
        
        <!-- 复制链接按钮（不支持直接打开时） -->
        <view class="open-platform-btn secondary" bindtap="openVideoLink" wx:if="{{isPlatformVideo && !canOpenApp}}">
          <image src="/images/share.png" mode="aspectFit"/>
          <text>复制链接去{{platformName}}观看</text>
        </view>
      </view>
    </block>

    <!-- 普通类型菜谱 -->
    <block wx:else>
      <!-- 菜谱图片 -->
      <view class="hero-section">
        <image class="hero-image {{!recipe.imageUrl ? 'placeholder' : ''}}" 
               src="{{recipe.imageUrl || '/images/default-food.png'}}" 
               mode="aspectFill"/>
        <view class="hero-overlay">
          <view class="cuisine-tag">{{recipe.cuisine || '自定义'}}</view>
        </view>
        <view class="back-btn" bindtap="goBack">
          <image src="/images/back.png" mode="aspectFit"/>
        </view>
      </view>

      <!-- 菜谱信息 -->
      <view class="info-section">
        <text class="recipe-name">{{recipe.name}}</text>
        
        <view class="recipe-meta">
          <view class="meta-item">
            <image src="/images/time.png" mode="aspectFit"/>
            <text>{{recipe.cookTime || '30'}}分钟</text>
          </view>
        </view>

        <!-- 标签 -->
        <view class="tags-section" wx:if="{{recipe.tags && recipe.tags.length > 0}}">
          <text class="tag" wx:for="{{recipe.tags}}" wx:key="*this">{{item}}</text>
        </view>
      </view>

      <!-- 食材清单 -->
      <view class="section ingredients-section">
        <view class="section-header">
          <text class="section-title">食材清单</text>
          <text class="section-count">{{recipe.ingredients.length || 0}}种食材</text>
        </view>
        <view class="ingredients-list">
          <view class="ingredient-item" wx:for="{{recipe.ingredients}}" wx:key="name">
            <view class="ingredient-dot"></view>
            <text class="ingredient-name">{{item.name}}</text>
            <text class="ingredient-amount">{{item.amount}}</text>
          </view>
        </view>
      </view>

      <!-- 烹饪步骤 -->
      <view class="section steps-section">
        <view class="section-header">
          <text class="section-title">烹饪步骤</text>
          <text class="section-count">共 {{recipe.steps.length || 0}} 步</text>
        </view>
        <view class="steps-list">
          <view class="step-item" wx:for="{{recipe.steps}}" wx:key="order">
            <view class="step-number">{{item.order}}</view>
            <view class="step-content">
              <image class="step-image" 
                     wx:if="{{item.imageUrl}}"
                     src="{{item.imageUrl}}" 
                     mode="aspectFill"/>
              <text class="step-text">{{item.description}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 来源信息 -->
      <view class="source-section" wx:if="{{recipe.source}}">
        <text class="source-label">菜谱来源：{{recipe.source}}</text>
      </view>
    </block>

    <!-- 底部间距 -->
    <view class="bottom-spacer"></view>
  </view>

  <!-- 底部固定操作栏 -->
  <view class="bottom-bar">
    <view class="bottom-action {{isFavorite ? 'favorited' : 'favorite'}}" bindtap="toggleFavorite">
      <image src="{{isFavorite ? '/images/heart-filled.png' : '/images/heart.png'}}" mode="aspectFit"/>
      <text>{{isFavorite ? '已收藏' : '收藏'}}</text>
    </view>
  </view>
</block>
